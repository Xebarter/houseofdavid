rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    // Public read for storefront data
    match /categories/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /brands/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /products/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /product_notes/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /journal_categories/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /journal_posts/{docId} {
      allow read: if resource.data.published == true || isAdmin();
      allow write: if isAdmin();
    }

    // Customers: anyone can read/create/update (needed for checkout upsert), only admin can delete
    match /customers/{docId} {
      allow read, create, update: if true;
      allow delete: if isAdmin();
    }

    // Orders: anyone can create (checkout), only admin can read/update
    match /orders/{docId} {
      allow create: if true;
      allow read, update: if isAdmin();
    }

    match /order_items/{docId} {
      allow create: if true;
      allow read: if isAdmin();
    }
  }
}
