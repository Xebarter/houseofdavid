# Public site URL (production). Used for metadata, share links, and OAuth redirects.
NEXT_PUBLIC_SITE_URL=https://houseofdavid-woad.vercel.app

# Firebase Client (public — safe in browser; NOT enough for admin scripts)
# Enable Google sign-in in Firebase Console → Authentication → Sign-in method
# authDomain is always your-project.firebaseapp.com (NOT your Vercel/custom domain).
# After deploying, run: npm run firebase:add-domain
# Or add the Vercel host manually in Firebase Console → Authentication → Settings → Authorized domains
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=house-of-david-4a0d1.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=house-of-david-4a0d1
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Named Firestore database (must match firebase.json → firestore.database)
NEXT_PUBLIC_FIRESTORE_DATABASE_ID=houseofdavid

# Firebase Admin (server-only — never expose to client)
# Option A: path to downloaded service account JSON (recommended)
FIREBASE_SERVICE_ACCOUNT_PATH=firebase/service-account.json
# Option B: paste fields from that JSON instead
# FIREBASE_PROJECT_ID is optional if NEXT_PUBLIC_FIREBASE_PROJECT_ID is set
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
# Paytota Payment Gateway (server-only)
PAYTOTA_BASE_URL=https://gate.paytota.com
PAYTOTA_SECRET_KEY=
PAYTOTA_BRAND_ID=
PAYTOTA_CURRENCY=UGX
# Optional: RSA public key for webhook signature verification
PAYTOTA_PUBLIC_KEY=
